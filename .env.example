# Copy this file to ".env" before running: cp .env.example .env
# Then change the values below (especially the passwords/secret).

# --- PostgreSQL database ---
POSTGRES_USER=alfath
POSTGRES_PASSWORD=change-this-password
POSTGRES_DB=alfath

# --- API server ---
# A long random string. Keep it secret. If you change it, everyone must log in again.
JWT_SECRET=change-this-to-a-long-random-string

# --- Web (the address you open in the browser) ---
# The app will be available at http://SERVER_IP:WEB_PORT
WEB_PORT=8080

# --- Automated database backups (written to ./backups on the host) ---
# How often to back up, in seconds. 21600 = every 6 hours. 3600 = hourly.
BACKUP_INTERVAL_SECONDS=21600
# How many days of backups to keep before deleting old ones.
BACKUP_KEEP_DAYS=14
